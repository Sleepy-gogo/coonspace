---
interface Props {
  text: string;
}

const text = Astro.props.text;
---

<button
  type="button"
  class="py-2.5 px-5 me-2 mb-2 text-sm font-medium focus:outline-none rounded-full border focus:z-10 focus:ring-2 focus:ring-purple-400 bg-blue-200/10 text-slate-100 border-blue-200/20 hover:bg-blue-200/20 transition-colors"
>
  {text}
</button>
