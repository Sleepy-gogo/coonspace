---
import Background from '../components/Background.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Online Markdown</title>
  </head>
  <body class="bg-slate-900 text-white relative overflow-hidden ">
    <Header />
    <slot />
    <Background />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100vw;
    height: 100%;
    font-family:
      InterVariable,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      Segoe UI,
      Roboto,
      Helvetica Neue,
      Arial,
      Noto Sans,
      sans-serif,
      'Apple Color Emoji',
      'Segoe UI Emoji',
      Segoe UI Symbol,
      'Noto Color Emoji';
  }
</style>
